# ══════════════════════════════════════════════════════
# GH05T3 v3 — ENVIRONMENT CONFIGURATION
# Copy to .env in your GH05T3 repo root
# ══════════════════════════════════════════════════════

# ── TRI-GPU MESH ────────────────────────────────────────
VLLM_PRIMARY_URL=http://localhost:8010     # RTX 5050 dGPU  (avoid clash with gateway)
LLAMA_VERIFIER_URL=http://localhost:8011   # Radeon 780M
LLAMA_FALLBACK_URL=http://localhost:8012   # Ryzen 7 CPU
GATEWAY_URL=http://localhost:8001          # gateway_v3 (server.py keeps 8000)
GATEWAY_PORT=8001

# ── CLAUDE API ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...              # Get from console.anthropic.com

# ── GITHUB ─────────────────────────────────────────────
GITHUB_PAT=ghp_...                        # Settings → Developer → Personal Access Tokens
GITHUB_REPO=leerobber/GH05T3
GITHUB_BRANCH=main
GITHUB_WEBHOOK_SECRET=your-webhook-secret  # Set in repo Settings → Webhooks
GH05T3_REPO_PATH=/home/terry/GH05T3       # Local clone path on TatorTot

# ── FRONTEND ───────────────────────────────────────────
REACT_APP_GW3_URL=http://localhost:8001    # v3 gateway URL for SwarmBusPanel

# ── SECURITY ───────────────────────────────────────────
KILLSWITCH_KEY_HASH=                       # SHA-256 of your owner key
GH05T3_SECRET=sovereign-ghost-mesh-key-2025

# ── MEMORY ─────────────────────────────────────────────
MEMORY_DB_PATH=memory/palace.db
SAGE_ELITE_THRESHOLD=0.90
KAIROS_META_REWRITE_TRIGGER=5

# ── TIA ANDROID ────────────────────────────────────────
TIA_WEBHOOK_SECRET=
TIA_HEARTBEAT_INTERVAL=30
